DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internflow?schema=public
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret
AUTH_SESSION_SECRET=dev-session-secret
REDIS_URL=redis://localhost:6379
LOCAL_DEV_MODE=true
ENABLE_DEMO_LOGIN=true
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true
OTP_TTL_SECONDS=600
OTP_STORE_BACKEND=auto
OTP_REDIS_KEY_PREFIX=internflow:otp:
OTP_ENFORCE_DURABLE=false
OTP_ALLOW_MEMORY_FALLBACK=true

STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=internflow-docs

OBS_AK=
OBS_SK=
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_ENDPOINT=
OBS_BUCKET=
OBS_REGION=

MAIL_FROM=no-reply@internflow.local
# Host machine `npm run dev` => localhost, Dockerized Next.js => mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

ENABLE_AI_ENRICHMENT=false
OPENROUTER_MODEL=openrouter/free
OPENROUTER_API_KEY=
OPENROUTER_TIMEOUT_MS=45000

# Set true on Windows when file watching is unstable
WATCHPACK_POLLING=false
