NODE_ENV=production
APP_URL=http://<ECS_PUBLIC_IP>

# Database (Normal mode: Huawei RDS)
DATABASE_URL=postgresql://internflow:<PASSWORD>@<RDS_PRIVATE_IP>:5432/internflow?schema=public

# Cheap mode fallback (docker postgres)
# DATABASE_URL=postgresql://internflow:internflow@postgres:5432/internflow?schema=public

# Auth / OTP
NEXTAUTH_SECRET=change-me-long-random
AUTH_SESSION_SECRET=change-me-long-random-session-secret
OTP_TTL_SECONDS=600
ENABLE_CONSOLE_OTP=false
ENABLE_DEMO_LOGIN=false
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false
OTP_STORE_BACKEND=redis
OTP_REDIS_KEY_PREFIX=internflow:otp:
OTP_ENFORCE_DURABLE=true
OTP_ALLOW_MEMORY_FALLBACK=false

# SMTP (competition safe)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@internflow.local

# Storage / OBS
STORAGE_PROVIDER=obs
OBS_BUCKET=internflow-docs
OBS_REGION=af-south-1
OBS_ENDPOINT=https://obs.af-south-1.myhuaweicloud.com
OBS_ACCESS_KEY=<AK>
OBS_SECRET_KEY=<SK>
# Backward-compatible aliases
OBS_AK=<AK>
OBS_SK=<SK>

# OCR (Huawei)
ENABLE_OCR=false
OCR_ENABLED_DOC_TYPES=ID,CERTIFICATE,PROOF_OF_ADDRESS
HUAWEI_OCR_ENDPOINT=https://ocr.af-south-1.myhuaweicloud.com/v2/{project_id}/ocr/web-image
HUAWEI_PROJECT_ID=<PROJECT_ID>
HUAWEI_ACCESS_KEY=<AK>
HUAWEI_SECRET_KEY=<SK>

# Exports
EXPORT_STORAGE_PREFIX=exports/closeout

# Redis / queues
REDIS_URL=redis://127.0.0.1:6379

# Optional notifications webhook
CONTACT_WHATSAPP_WEBHOOK_URL=
