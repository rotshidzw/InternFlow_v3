{
  "name": "internflow-v3",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "npm run db:push --workspace @internflow/db",
    "db:seed": "npm run db:seed --workspace @internflow/db",
    "format": "prettier --check .",
    "db:generate": "npm run db:generate --workspace @internflow/db",
    "predev": "node scripts/ensure-deps.mjs",
    "check:prod-env": "node scripts/validate-production-env.mjs",
    "check:local-env": "node scripts/validate-local-env.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "prettier": "^3.3.3",
    "turbo": "^2.1.1",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "nodemailer": "^7.0.13"
  }
}
