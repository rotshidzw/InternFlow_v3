generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  SUPERVISOR
  COORDINATOR
  PROVIDER_ADMIN
  SYSTEM_ADMIN
}

enum DocStatus {
  PENDING
  PASS
  FAIL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  REVIEW
  ACCEPTED
  REJECTED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  role          Role
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  memberships   Membership[]
  profile       Profile?
  applications  Application[]
  enrollments   Enrollment[]
  documents     Document[]
  logbookEntries LogbookEntry[]
  tickets       Ticket[]
  chatMessages  ChatMessage[]
  auditLogs     AuditLog[]
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  memberships Membership[]
  invites     Invite[]
  programs    Program[]
  cohorts     Cohort[]
  settings    Settings[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Invite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           Role
  token          String       @unique
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  phone            String?
  education        String?
  bankingDetails   String?
  emergencyContact String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Program {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String
  startDate      DateTime
  endDate        DateTime
  opportunities  Opportunity[]
  enrollments    Enrollment[]
  templates      ChecklistTemplate[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id          String        @id @default(cuid())
  programId   String
  title       String
  description String
  capacity    Int
  applications Application[]
  program     Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Application {
  id            String            @id @default(cuid())
  userId         String
  opportunityId  String
  status         ApplicationStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity    Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  checklist      ChecklistInstance?
}

model Cohort {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  startDate      DateTime
  endDate        DateTime
  enrollments    Enrollment[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String   @id @default(cuid())
  userId       String
  programId    String
  cohortId     String?
  stipendPaid  Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  cohort       Cohort?  @relation(fields: [cohortId], references: [id], onDelete: SetNull)
}

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  programId String
  name      String
  items     ChecklistItemTemplate[]
  program   Program                 @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model ChecklistItemTemplate {
  id          String            @id @default(cuid())
  templateId   String
  label        String
  required     Boolean           @default(true)
  expiryDays   Int?
  template     ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChecklistInstance {
  id            String                  @id @default(cuid())
  applicationId String                  @unique
  progress      Int                     @default(0)
  items         ChecklistItemInstance[]
  application   Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ChecklistItemInstance {
  id            String            @id @default(cuid())
  checklistId   String
  label         String
  status        String            @default("PENDING")
  dueDate       DateTime?
  checklist     ChecklistInstance @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Document {
  id               String            @id @default(cuid())
  userId           String
  organizationId   String?
  type             String
  status           DocStatus         @default(PENDING)
  rejectionReason  String?
  selfCertifiedAt  DateTime?
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions         DocumentVersion[]
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  storageKey  String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model GeneratedDocument {
  id         String   @id @default(cuid())
  userId     String
  type       String
  storageKey String
  createdAt  DateTime @default(now())
}

model LogbookEntry {
  id          String            @id @default(cuid())
  userId      String
  weekStart   DateTime
  summary     String
  evidenceKey String?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvals   LogbookApproval[]
}

model LogbookApproval {
  id          String      @id @default(cuid())
  entryId      String
  reviewerId   String
  status       String
  comment      String?
  createdAt    DateTime   @default(now())
  entry        LogbookEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model Ticket {
  id         String        @id @default(cuid())
  userId     String
  title      String
  summary    String
  status     TicketStatus  @default(OPEN)
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     TicketEvent[]
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  actorId   String?
  event     String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String?
  role      String
  body      String
  createdAt DateTime @default(now())
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Settings {
  id             String       @id @default(cuid())
  organizationId String?
  key            String
  value          Json
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
